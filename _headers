/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: default-src 'self'; script-src 'self' https://www.gstatic.com https://unpkg.com; style-src 'self' https://fonts.googleapis.com 'unsafe-inline'; font-src https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://*.googleapis.com https://*.firebaseio.com https://*.firebaseapp.com; frame-ancestors 'none'
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

/*.html
  Cache-Control: no-store, no-cache, must-revalidate, proxy-revalidate

/*.css
  Cache-Control: no-store, no-cache, must-revalidate, proxy-revalidate

/*.js
  Cache-Control: no-store, no-cache, must-revalidate, proxy-revalidate

/sitemap.xml
  Content-Type: application/xml; charset=utf-8
  Cache-Control: public, max-age=0
  X-Robots-Tag: noindex

/sitemap_zaproshenya.xml
  Content-Type: application/xml; charset=utf-8
  Cache-Control: public, max-age=0

/i/*
  X-Robots-Tag: noindex

/g/*
  X-Robots-Tag: noindex

/user/*
  X-Robots-Tag: noindex

/robots.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=0

/manifest.json
  Content-Type: application/json; charset=utf-8

/favicon.svg
  Content-Type: image/svg+xml
  Cache-Control: public, max-age=604800

/favicon.png
  Content-Type: image/png
  Cache-Control: public, max-age=604800

/firebase-messaging-sw.js
  Cache-Control: no-cache
  Service-Worker-Allowed: /
