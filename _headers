/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: default-src 'self'; script-src 'self' https://www.gstatic.com https://unpkg.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://*.firebaseio.com wss://*.firebaseio.com https://www.googleapis.com; manifest-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

/*.html
  Cache-Control: public, max-age=3600

/js/*
  Cache-Control: public, max-age=31536000, immutable

/css/*
  Cache-Control: public, max-age=31536000, immutable

/sitemap.xml
  Content-Type: text/xml; charset=utf-8
  Cache-Control: public, max-age=3600

/i/*
  X-Robots-Tag: noindex

/g/*
  X-Robots-Tag: noindex

/user/*
  X-Robots-Tag: noindex

/robots.txt
  Content-Type: text/plain; charset=utf-8

/manifest.json
  Content-Type: application/json; charset=utf-8

/favicon.svg
  Content-Type: image/svg+xml
  Cache-Control: public, max-age=604800

/firebase-messaging-sw.js
  Cache-Control: no-cache
  Service-Worker-Allowed: /
