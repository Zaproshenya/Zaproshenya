{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/g/[id]",
      "regex": "^/g/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/g/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/g/[id]/opengraph-image",
      "regex": "^/g/([^/]+?)/opengraph\\-image(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/g/(?<nxtPid>[^/]+?)/opengraph\\-image(?:/)?$"
    },
    {
      "page": "/g/[id]/p",
      "regex": "^/g/([^/]+?)/p(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/g/(?<nxtPid>[^/]+?)/p(?:/)?$"
    },
    {
      "page": "/i/[id]",
      "regex": "^/i/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
