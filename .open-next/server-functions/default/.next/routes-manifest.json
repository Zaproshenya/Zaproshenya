      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/i/(?<nxtPid>[^/]+?)/opengraph\\-image(?:/)?$"
    },
    {
      "page": "/i/[id]/p",
      "regex": "^/i/([^/]+?)/p(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/i/(?<nxtPid>[^/]+?)/p(?:/)?$"
