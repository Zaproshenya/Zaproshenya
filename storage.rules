rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Support chat attachments
    match /support-chat/{ticketId}/{allPaths=**} {
      // Ticket author and moderators can read
      allow read: if request.auth != null;
      // Only authenticated users can upload, max 10MB, images only
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Avatar uploads — users can only write their own avatar
    match /avatars/{uid}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Admin publisher temp uploads — allows both videos and images up to 100MB
    // Must be publicly readable so that social media APIs (TikTok, Instagram, YouTube) can download the file.
    match /temp_publisher/{uid}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid
        && request.resource.size < 100 * 1024 * 1024;
    }
  }
}
